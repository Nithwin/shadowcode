{
  "id": "shadow-dark",
  "label": "Shadow Dark",
  "uiTheme": "vs-dark",
  "colors": {
    "focusBorder": "#7c3aed",
    "editor.background": "#0d0d14",
    "editor.foreground": "#e2e8f0",
    "sideBar.background": "#080810",
    "sideBar.foreground": "#e2e8f0",
    "activityBar.background": "#0a0a0f",
    "activityBar.foreground": "#e2e8f0",
    "titleBar.activeBackground": "#0a0a0f",
    "titleBar.activeForeground": "#e2e8f0",
    "statusBar.background": "#0a0a0f",
    "statusBar.foreground": "#e2e8f0",
    "button.background": "#7c3aed",
    "button.foreground": "#ffffff",
    "errorForeground": "#f87171",
    "commandCenter.background": "#0a0a0f",
    "commandCenter.foreground": "#cbd5e1",
    "commandCenter.border": "#1e1e2e",
    "commandCenter.activeBackground": "#1e1e2e",
    "commandCenter.activeForeground": "#7c3aed",
    "commandCenter.activeBorder": "#7c3aed",
    "editorGroupHeader.tabsBackground": "#080810",
    "tab.activeBackground": "#1e1e2e",
    "tab.activeForeground": "#7c3aed",
    "tab.activeBorder": "#7c3aed",
    "tab.inactiveBackground": "#0a0a0f",
    "tab.inactiveForeground": "#64748b"

  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#4a4a6a"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "variable.language",
        "support.type"
      ],
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#34d399"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#60a5fa"
      }
    },
    {
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#f87171"
      }
    }
  ]
}
